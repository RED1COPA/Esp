-- ESP

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer
local ESP = {}


local  teamState =
{ state = teamCheckOn }




local function createHighlight()
local hl = Instance.new("Highlight")
hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
hl.Enabled = false
pcall(function() hl.Parent = game.CoreGui end)
return hl
end

local function createESP(player)
if player == LocalPlayer or ESP[player] then return end
local name = Drawing.new("Text")
name.Size = 14
name.Center = true
name.Outline = true
name.Font = 2
name.Visible = false

local box = Drawing.new("Square")
box.Thickness = 1.5
box.Filled = false
box.Visible = false

local highlight = createHighlight()
ESP[player] = { name = name, box = box, highlight = highlight }

if player.Character then
highlight.Adornee = player.Character
end
player.CharacterAdded:Connect(function(char)
highlight.Adornee = char
end)

end

local function removeESP(player)
local data = ESP[player]
if not data then return end
pcall(function() data.name:Remove() end)
pcall(function() data.box:Remove() end)
if data.highlight then data.highlight:Destroy() end
ESP[player] = nil
end

for _, player in ipairs(Players:GetPlayers()) do createESP(player) end
Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)

-- New function to determine if all enemies are on the same team
local function getEnemyTeamColorMap()
local enemyTeams = {}
for _, player in ipairs(Players:GetPlayers()) do
if player ~= LocalPlayer and player.Team ~= LocalPlayer.Team then
local char = player.Character
local hum = char and char:FindFirstChildOfClass("Humanoid")
if hum and hum.Health > 0 then
enemyTeams[player.Team] = true
end
end
end
local uniqueTeams = 0
for _ in pairs(enemyTeams) do uniqueTeams += 1 end
return uniqueTeams == 1 and Color3.fromRGB(151, 0, 0) or nil
end

RunService.RenderStepped:Connect(function()
  local overrideEnemyColor = getEnemyTeamColorMap()

for player, data in pairs(ESP) do
local char = player.Character
local hum = char and char:FindFirstChildOfClass("Humanoid")
local hrp = char and char:FindFirstChild("HumanoidRootPart")
local head = char and char:FindFirstChild("Head")
local skip = teamState.state and player.Team == LocalPlayer.Team

if hrp and head and hum and hum.Health > 0 and not skip then
local pos, visible = Camera:WorldToViewportPoint(hrp.Position)
local top = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
local bottom = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))
local height = math.abs(top.Y - bottom.Y)
local width = height / 2
local color = (overrideEnemyColor and player.Team ~= LocalPlayer.Team) and overrideEnemyColor or player.TeamColor.Color

if visible then
data.name.Text = player.Name
data.name.Position = Vector2.new(pos.X, top.Y - 16)
data.name.Color = color
data.name.Visible = true

data.box.Position = Vector2.new(pos.X - width / 2, top.Y)
data.box.Size = Vector2.new(width, height)
data.box.Color = color
data.box.Visible = true

data.highlight.FillColor = color
data.highlight.OutlineColor = color
data.highlight.Enabled = true

else
data.name.Visible = false
data.box.Visible = false
data.highlight.Enabled = false
end

else
data.name.Visible = false
data.box.Visible = false
data.highlight.Enabled = false
end

end

end)
