-- ESP ONLY (ALWAYS ON, NO GUI)
assert(Drawing, "Your exploit does not support Drawing API")

local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local Camera = workspace.CurrentCamera
local LocalPlayer = Players.LocalPlayer

-- ESP STORAGE
local ESP = {}

local function createHighlight()
    local hl = Instance.new("Highlight")
    hl.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    hl.Enabled = false
    pcall(function() hl.Parent = game.CoreGui end)
    return hl
end

local function createESP(player)
    if player == LocalPlayer or ESP[player] then return end

    local name = Drawing.new("Text")
    name.Size = 14
    name.Center = true
    name.Outline = true
    name.Font = 2
    name.Visible = false

    local box = Drawing.new("Square")
    box.Thickness = 1.5
    box.Filled = false
    box.Visible = false

    local highlight = createHighlight()

    ESP[player] = {
        name = name,
        box = box,
        highlight = highlight
    }

    if player.Character then
        highlight.Adornee = player.Character
    end

    player.CharacterAdded:Connect(function(char)
        highlight.Adornee = char
    end)
end

local function removeESP(player)
    local data = ESP[player]
    if not data then return end

    pcall(function() data.name:Remove() end)
    pcall(function() data.box:Remove() end)
    if data.highlight then data.highlight:Destroy() end

    ESP[player] = nil
end

-- Init
for _, p in ipairs(Players:GetPlayers()) do
    createESP(p)
end

Players.PlayerAdded:Connect(createESP)
Players.PlayerRemoving:Connect(removeESP)

-- ESP LOOP (ALWAYS ON)
RunService.RenderStepped:Connect(function()
    for player, data in pairs(ESP) do
        local char = player.Character
        local hum = char and char:FindFirstChildOfClass("Humanoid")
        local hrp = char and char:FindFirstChild("HumanoidRootPart")
        local head = char and char:FindFirstChild("Head")

        if hrp and head and hum and hum.Health > 0 then
            local pos, visible = Camera:WorldToViewportPoint(hrp.Position)
            local top = Camera:WorldToViewportPoint(head.Position + Vector3.new(0, 0.5, 0))
            local bottom = Camera:WorldToViewportPoint(hrp.Position - Vector3.new(0, 3, 0))

            local height = math.abs(top.Y - bottom.Y)
            local width = height / 2

            -- FIXED COLOR (RED)
            local color = Color3.fromRGB(255, 0, 0)

            if visible then
                data.name.Text = player.Name
                data.name.Position = Vector2.new(pos.X, top.Y - 16)
                data.name.Color = color
                data.name.Visible = true

                data.box.Position = Vector2.new(pos.X - width/2, top.Y)
                data.box.Size = Vector2.new(width, height)
                data.box.Color = color
                data.box.Visible = true

                data.highlight.FillColor = color
                data.highlight.OutlineColor = color
                data.highlight.Enabled = true
            else
                data.name.Visible = false
                data.box.Visible = false
                data.highlight.Enabled = false
            end
        else
            data.name.Visible = false
            data.box.Visible = false
            data.highlight.Enabled = false
        end
    end
end)

print("ESP Loaded (Always On, No GUI)")
